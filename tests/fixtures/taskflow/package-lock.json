{
  "name": "taskflow",
  "version": "1.2.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "taskflow",
      "version": "1.2.0",
      "workspaces": [
        "packages/*",
        "services/*"
      ],
      "engines": {
        "node": ">=20.6.0"
      }
    },
    "node_modules/@taskflow/api": {
      "resolved": "services/api",
      "link": true
    },
    "node_modules/@taskflow/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@taskflow/worker": {
      "resolved": "services/worker",
      "link": true
    },
    "packages/shared": {
      "name": "@taskflow/shared",
      "version": "1.2.0"
    },
    "services/api": {
      "name": "@taskflow/api",
      "version": "1.2.0",
      "dependencies": {
        "@taskflow/shared": "1.2.0"
      }
    },
    "services/worker": {
      "name": "@taskflow/worker",
      "version": "1.2.0",
      "dependencies": {
        "@taskflow/shared": "1.2.0"
      }
    }
  }
}
